<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/api_test"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/clear_log_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear" />
    </LinearLayout>

    <EditText
        android:id="@+id/device_num_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/enter_device_number"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/log_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/test_geocode_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_geocode"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4CAF50" />

        <Button
            android:id="@+id/test_bind_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_bind_device"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/test_unbind_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_unbind_device"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#FF5722" />

        <Button
            android:id="@+id/test_refresh_location_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_refresh_location"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/test_device_info_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_get_device_info" />
    </LinearLayout>

</LinearLayout>