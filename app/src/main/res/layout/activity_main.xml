<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 首页右上角：当前语言 -->
    <TextView
        android:id="@+id/current_language_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:background="@drawable/bg_language_indicator"
        android:visibility="gone"
        android:elevation="6dp"
        android:contentDescription="@string/current_language_cd"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fragment容器（包含地图，全屏显示） -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 地图控件（由MainActivity直接管理） -->
        <FrameLayout
            android:id="@+id/map_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.amap.api.maps.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <fragment
                android:id="@+id/google_map_fragment"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- 自定义指南针（替代SDK指南针，位置可自定义） -->
        <ImageView
            android:id="@+id/custom_compass"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="50dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_compass"
            android:visibility="gone"
            android:contentDescription="@string/compass" />

    </FrameLayout>

    <!-- 首页浮动按钮（高德风格：白底圆角 + 黑色图标，紧贴设备信息栏上方） -->
    <LinearLayout
        android:id="@+id/map_floating_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_info">

        <ImageButton
            android:id="@+id/refresh_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_refresh"
            android:background="@drawable/bg_map_floating_button"
            android:elevation="4dp"
            android:contentDescription="@string/refresh" />

        <ImageButton
            android:id="@+id/map_type_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_map_type"
            android:background="@drawable/bg_map_floating_button"
            android:elevation="4dp"
            android:contentDescription="@string/map_type" />

        <ImageButton
            android:id="@+id/locate_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_locate"
            android:background="@drawable/bg_map_floating_button"
            android:elevation="4dp"
            android:contentDescription="@string/locate" />

    </LinearLayout>

    <!-- 底部信息栏（浮在地图上方，仅在首页显示） -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_info"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_power_off" />

                <TextView
                    android:id="@+id/battery_level"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:text="@string/battery_level"
                    android:textSize="13sp"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_map" />

                <TextView
                    android:id="@+id/device_address"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:text="@string/address"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/scan_status_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_recent_history" />

                <TextView
                    android:id="@+id/update_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:text="@string/last_update"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/scanning_indicator"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginLeft="8dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:orientation="horizontal"
        android:background="@color/top_bar_background"
        android:paddingBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/tab_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_home_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_home" />

            <TextView
                android:id="@+id/tab_home_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_home"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 列表 -->
        <LinearLayout
            android:id="@+id/tab_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_list_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_list" />

            <TextView
                android:id="@+id/tab_list_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_list"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 轨迹 -->
        <LinearLayout
            android:id="@+id/tab_track"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_track_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_track" />

            <TextView
                android:id="@+id/tab_track_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_track"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 我的 -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_profile_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_profile" />

            <TextView
                android:id="@+id/tab_profile_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_profile"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
