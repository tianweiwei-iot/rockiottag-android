<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivityOptimized">

    <!-- 地图Fragment容器 -->
    <FrameLayout
        android:id="@+id/map_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/device_control_fragment_container"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 刷新按钮 -->
    <ImageButton
        android:id="@+id/refresh_btn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="14dp"
        android:src="@drawable/ic_refresh"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/map_type_btn" />

    <!-- 切换卫星地图按钮 -->
    <ImageButton
        android:id="@+id/map_type_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="3dp"
        android:layout_marginBottom="-5dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_map_type"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/locate_btn" />

    <!-- 手动回到当前位置按钮 -->
    <ImageButton
        android:id="@+id/locate_btn"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="278dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_locate"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 设备控制Fragment容器 -->
    <FrameLayout
        android:id="@+id/device_control_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/control_bar" />

    <!-- 控制栏（移动到底部，包含菜单、轨迹、蜂鸣器） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/top_bar_background"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/menu_btn_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:minWidth="60dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/menu_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:includeFontPadding="false"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/device_name_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/menu_btn_container"
            app:layout_constraintEnd_toStartOf="@id/track_btn_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/device_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="tag"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/device_tag_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="16sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/no_device_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_device_selected"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/menu_btn_container"
            app:layout_constraintEnd_toStartOf="@id/track_btn_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:id="@+id/track_btn_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:minWidth="60dp"
            app:layout_constraintEnd_toStartOf="@id/buzzer_btn_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/track_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_track"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/track"
                android:textSize="11sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/buzzer_btn_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:minWidth="60dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/buzzer_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_buzzer"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/buzzer"
                android:textSize="11sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
