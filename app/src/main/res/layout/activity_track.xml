<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TrackActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingTop="0dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/track"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/back_btn"
            app:layout_constraintEnd_toStartOf="@id/prev_day_btn"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/prev_day_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_prev_day"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toStartOf="@id/date_btn"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/date_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/today"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:minWidth="60dp"
            android:paddingTop="0dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toStartOf="@id/next_day_btn"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/next_day_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_next_day"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/time_range_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_range"
            android:textSize="13sp"
            android:textColor="#333333" />

        <Button
            android:id="@+id/start_time_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/start_time_default"
            android:contentDescription="@string/select_start_time"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:minWidth="60dp"
            android:layout_marginStart="6dp"
            android:paddingTop="0dp"
            android:paddingBottom="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_separator"
            android:textSize="14sp"
            android:textColor="#333333"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/end_time_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/end_time_default"
            android:contentDescription="@string/select_end_time"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:minWidth="60dp"
            android:paddingTop="0dp"
            android:paddingBottom="1dp" />

        <Button
            android:id="@+id/reset_time_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/reset"
            android:textSize="11sp"
            android:textColor="#333333"
            android:backgroundTint="#9E9E9E"
            android:layout_marginStart="8dp"
            android:paddingTop="0dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

    <!-- 加载进度条 -->
    <ProgressBar
        android:id="@+id/loading_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="0dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/time_range_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.amap.api.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/playback_control_bar"
        app:layout_constraintTop_toBottomOf="@id/time_range_container" />

    <fragment
        android:id="@+id/googleMapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/playback_control_bar"
        app:layout_constraintTop_toBottomOf="@id/time_range_container" />

    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF"
        android:elevation="3dp"
        android:padding="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/time_range_container">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/toggle_markers_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="@string/toggle_markers_desc" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/markers"
                android:textSize="9sp"
                android:textColor="#333333" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <ImageButton
                android:id="@+id/toggle_polyline_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="@string/toggle_polyline_desc" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/polyline"
                android:textSize="9sp"
                android:textColor="#333333" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <ImageButton
                android:id="@+id/toggle_satellite_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="@string/toggle_satellite_desc" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/satellite"
                android:textSize="9sp"
                android:textColor="#333333" />

        </LinearLayout>

        <!-- 统计按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <ImageButton
                android:id="@+id/statistics_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_today"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="@string/statistics" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/statistics"
                android:textSize="9sp"
                android:textColor="#333333" />

        </LinearLayout>

        <!-- 刷新按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <ImageButton
                android:id="@+id/refresh_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="@string/refresh" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/refresh"
                android:textSize="9sp"
                android:textColor="#333333" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/playback_control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="0dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="3dp"
        android:paddingBottom="4dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <!-- 精度调节控件 -->
        <LinearLayout
            android:id="@+id/accuracy_control_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="6dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accuracy_adjustment"
                android:textSize="11sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/high_accuracy"
                    android:textSize="10sp"
                    android:textColor="#666666" />

                <SeekBar
                    android:id="@+id/accuracy_seekbar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/low_accuracy"
                    android:textSize="10sp"
                    android:textColor="#666666" />

            </LinearLayout>

            <TextView
                android:id="@+id/accuracy_value_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accuracy_default_value"
                android:textSize="10sp"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/play_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/current_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_format_hh_mm_ss"
                android:textSize="10sp"
                android:textColor="#333333"
                android:layout_marginStart="3dp" />

            <SeekBar
                android:id="@+id/playback_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/total_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_format_hh_mm_ss"
                android:textSize="10sp"
                android:textColor="#333333"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/speed_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/speed_1x"
                android:textSize="12sp"
                android:textColor="#2196F3"
                android:padding="3dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/track_point_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/time_placeholder"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/track_point_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loading"
                        android:textSize="9sp"
                        android:textColor="#666666"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:layout_marginTop="0dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F5F5F5"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_distance"
                        android:textSize="10sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/total_distance_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/distance_format"
                        android:textSize="12sp"
                        android:textColor="#2196F3"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/tab_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/tab_home_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_home" />
            <TextView
                android:id="@+id/tab_home_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_home"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- 列表 -->
        <LinearLayout
            android:id="@+id/tab_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/tab_list_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_list" />
            <TextView
                android:id="@+id/tab_list_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_list"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- 轨迹 -->
        <LinearLayout
            android:id="@+id/tab_track"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/tab_track_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_track" />
            <TextView
                android:id="@+id/tab_track_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_track"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- 我的 -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/tab_profile_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tab_profile" />
            <TextView
                android:id="@+id/tab_profile_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_profile"
                android:textSize="11sp"
                android:textColor="@drawable/tab_color_selector"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>