<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <ImageButton
        android:id="@+id/toggle_markers_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_mylocation"
        android:contentDescription="@string/toggle_markers"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <ImageButton
        android:id="@+id/toggle_polyline_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_directions"
        android:contentDescription="@string/toggle_polyline"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <ImageButton
        android:id="@+id/toggle_satellite_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_mapmode"
        android:contentDescription="@string/toggle_satellite"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <ImageButton
        android:id="@+id/statistics_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_info_details"
        android:contentDescription="@string/statistics_info"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>
