# RockiotTag 敏感配置模板
# 复制此文件为 secrets.properties 并填入真实值（secrets.properties 已在 .gitignore 中）
# 也可通过同名环境变量注入（环境变量优先，适合 CI/CD）

# === 厂商 API 认证 ===
ROCKIOT_API_CID=
ROCKIOT_API_PASSWORD=

# === 地图 API Key ===
ROCKIOT_GOOGLE_MAPS_API_KEY=
ROCKIOT_AMAP_API_KEY=

# === 多客户 API Key（至少配置默认客户 HSWL） ===
ROCKIOT_CUSTOMER_HSWL_KEY=
ROCKIOT_CUSTOMER_DR_KEY=
ROCKIOT_CUSTOMER_DEMO_KEY=
ROCKIOT_CUSTOMER_HSWL_5GP02_KEY=
ROCKIOT_CUSTOMER_MEXBT_KEY=
ROCKIOT_CUSTOMER_GBRYE_KEY=
ROCKIOT_CUSTOMER_ALF_KEY=

# === 服务器 URL（可选，有默认值） ===
# SERVER_URL_12BIT=https://5gp.blackrockiot.com/api
# SERVER_URL_16BIT=https://5gp.blackrockiot.com/api
# VENDOR_API_URL=https://device.vernal.ltd/tagapi

# === Release 签名（Release 构建必填） ===
ROCKIOT_STORE_PASSWORD=
ROCKIOT_KEY_PASSWORD=
# ROCKIOT_KEY_ALIAS=myapp_key
